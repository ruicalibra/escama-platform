# ═══════════════════════════════════════════════════════════
# ESCAMA PLATFORM — Environment Variables
# Copy this file to .env.local and fill in the values
# ═══════════════════════════════════════════════════════════

# ─── DATABASE ───────────────────────────────────────────────
# PostgreSQL connection string
# Local: postgresql://USER:PASSWORD@localhost:5432/escama
# Supabase: get from dashboard > Settings > Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/escama"

# ─── NEXTAUTH ────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-min-32-chars-change-this"

# App URL (change for production)
NEXTAUTH_URL="http://localhost:3000"

# ─── GOOGLE OAUTH (optional) ─────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── APP CONFIG ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Escama"
NEXT_PUBLIC_TENANT_SLUG="escama-ao"

# ─── WHATSAPP (optional) ─────────────────────────────────────
# Twilio or direct WhatsApp Business API
WHATSAPP_API_KEY=""
WHATSAPP_PHONE_NUMBER=""
